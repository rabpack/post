{
    "name": "rabpack/post",
    "description": "A flexible shipping cost calculation package for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Meysam Nosrati",
            "email": "m.nosrati2019@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\Shipping\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\Shipping\\Providers\\ShippingServiceProvider"
            ],
            "aliases": {
                "Shipping": "Vendor\\Shipping\\Facades\\Shipping"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
